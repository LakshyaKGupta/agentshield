{
  "version": 2,
  "buildCommand": "cd frontend && npm ci && npm run build",
  "outputDirectory": "frontend/dist",
  "installCommand": "python3 -m pip install -r requirements.txt && cd frontend && npm ci",
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/favicon.svg",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.py" },
    { "source": "/ready", "destination": "/api/index.py" },
    { "source": "/health", "destination": "/api/index.py" },
    { "source": "/v1/:path*", "destination": "/api/index.py" },
    { "source": "/ws/:path*", "destination": "/api/index.py" },
    { "source": "/((?!assets/|favicon.svg).*)", "destination": "/index.html" }
  ]
}
