{
  "components": {
    "schemas": {
      "AgentCreateRequest": {
        "properties": {
          "metadata": {
            "additionalProperties": true,
            "title": "Metadata",
            "type": "object"
          },
          "name": {
            "maxLength": 120,
            "minLength": 1,
            "title": "Name",
            "type": "string"
          },
          "permissions": {
            "$ref": "#/components/schemas/PermissionManifest"
          },
          "type": {
            "default": "custom",
            "enum": [
              "user_agent",
              "research_agent",
              "executor_agent",
              "security_agent",
              "custom"
            ],
            "title": "Type",
            "type": "string"
          }
        },
        "required": [
          "name",
          "permissions"
        ],
        "title": "AgentCreateRequest",
        "type": "object"
      },
      "AnalyzeRequest": {
        "properties": {
          "agent_id": {
            "format": "uuid",
            "title": "Agent Id",
            "type": "string"
          },
          "context": {
            "additionalProperties": true,
            "title": "Context",
            "type": "object"
          },
          "deep_analysis": {
            "default": false,
            "title": "Deep Analysis",
            "type": "boolean"
          },
          "direction": {
            "enum": [
              "inbound",
              "outbound",
              "inter_agent"
            ],
            "title": "Direction",
            "type": "string"
          },
          "message": {
            "maxLength": 20000,
            "minLength": 1,
            "title": "Message",
            "type": "string"
          }
        },
        "required": [
          "agent_id",
          "direction",
          "message"
        ],
        "title": "AnalyzeRequest",
        "type": "object"
      },
      "AttackSimulationRequest": {
        "properties": {
          "attack_type": {
            "default": "instruction_override",
            "title": "Attack Type",
            "type": "string"
          },
          "payload": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Payload"
          }
        },
        "title": "AttackSimulationRequest",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "PermissionManifest": {
        "properties": {
          "default_action": {
            "const": "deny",
            "default": "deny",
            "title": "Default Action",
            "type": "string"
          },
          "max_risk_level": {
            "anyOf": [
              {
                "enum": [
                  "low",
                  "medium",
                  "high"
                ],
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Max Risk Level"
          },
          "tools": {
            "additionalProperties": {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "title": "Tools",
            "type": "object"
          }
        },
        "title": "PermissionManifest",
        "type": "object"
      },
      "ToolCallRequest": {
        "properties": {
          "action": {
            "maxLength": 120,
            "minLength": 1,
            "title": "Action",
            "type": "string"
          },
          "agent_id": {
            "format": "uuid",
            "title": "Agent Id",
            "type": "string"
          },
          "arguments_hash": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Arguments Hash"
          },
          "risk_context": {
            "additionalProperties": true,
            "title": "Risk Context",
            "type": "object"
          },
          "tool_name": {
            "maxLength": 120,
            "minLength": 1,
            "title": "Tool Name",
            "type": "string"
          }
        },
        "required": [
          "agent_id",
          "tool_name",
          "action"
        ],
        "title": "ToolCallRequest",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    }
  },
