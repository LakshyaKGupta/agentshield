# AgentShield Frontend Environment Variables
# Copy this to .env.local and fill in your values

# Backend API URL
VITE_API_URL=http://127.0.0.1:8000

# Firebase Configuration
# Get these from https://console.firebase.google.com/ > Project Settings > Web App
VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Dev quick-login credentials (for local testing only)
VITE_DEV_EMAIL=dev@agentshield.local
VITE_DEV_PASSWORD=devpass123
